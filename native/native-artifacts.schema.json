{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hopme.sh/schemas/native-artifacts-v1.json",
  "title": "Hop native artifact manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "version",
    "tag",
    "repository",
    "source_sha",
    "builder",
    "artifacts"
  ],
  "properties": {
    "schema": {
      "const": "https://hopme.sh/schemas/native-artifacts-v1.json"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "tag": {
      "type": "string",
      "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "repository": {
      "const": "https://github.com/hopmesh/hop"
    },
    "source_sha": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "builder": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository",
        "workflow",
        "run_id",
        "run_attempt",
        "identity"
      ],
      "properties": {
        "repository": {
          "const": "hopmesh/hop"
        },
        "workflow": {
          "const": ".github/workflows/native-artifacts.yml"
        },
        "run_id": {
          "type": "integer",
          "minimum": 1
        },
        "run_attempt": {
          "type": "integer",
          "minimum": 1
        },
        "identity": {
          "type": "string",
          "pattern": "^https://github\\.com/hopmesh/hop/actions/runs/[1-9][0-9]*$"
        }
      }
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "target",
          "filename",
          "sha256",
          "size",
          "archive"
        ],
        "properties": {
          "target": {
            "type": "string",
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:+-]*$"
          },
          "filename": {
            "type": "string",
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._+-]*\\.(tar\\.gz|zip)$"
          },
          "sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          },
          "size": {
            "type": "integer",
            "minimum": 1
          },
          "archive": {
            "type": "object",
            "additionalProperties": false,
            "required": ["format", "files"],
            "properties": {
              "format": {
                "enum": ["tar.gz", "zip"]
              },
              "files": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["path", "sha256", "size", "mode"],
                  "properties": {
                    "path": {
                      "type": "string",
                      "minLength": 1
                    },
                    "sha256": {
                      "type": "string",
                      "pattern": "^[0-9a-f]{64}$"
                    },
                    "size": {
                      "type": "integer",
                      "minimum": 0
                    },
                    "mode": {
                      "enum": ["0644", "0755"]
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
